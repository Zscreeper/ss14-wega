<controls:FancyWindow xmlns="https://spacestation14.io"
                     xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                     SetSize="350 220">
    <BoxContainer Orientation="Vertical" Margin="10">
        <BoxContainer Orientation="Vertical" HorizontalExpand="True">
            <PanelContainer Name="StatusPanel" StyleClasses="AngleRect" HorizontalExpand="True" VerticalExpand="False">
                <BoxContainer Orientation="Vertical" Margin="10 8" HorizontalExpand="True">
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                        <Label Text="{Loc 'prison-shuttle-status'}" StyleClasses="LabelBig" MinWidth="120"/>
                        <Label Name="StatusLabel" StyleClasses="LabelSubText" HorizontalExpand="True" HorizontalAlignment="Left"/>
                    </BoxContainer>

                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 5 0 0">
                        <Label Text="{Loc 'prison-shuttle-current-location'}" StyleClasses="LabelBig" MinWidth="120"/>
                        <Label Name="LocationLabel" StyleClasses="LabelSubText" HorizontalExpand="True" HorizontalAlignment="Left"/>
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <PanelContainer StyleClasses="AngleRect" HorizontalExpand="True" Margin="0 8 0 0">
                <BoxContainer Orientation="Vertical" Margin="10 12" HorizontalExpand="True">
                    <BoxContainer Orientation="Vertical" HorizontalExpand="True" HorizontalAlignment="Center">
                        <Button Name="CallButton"
                                StyleClasses="OpenButton"
                                MinWidth="150"
                                MinHeight="36"
                                Disabled="true"/>
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>

        <BoxContainer Orientation="Vertical" Margin="0 8 0 0">
            <Label Name="InfoLabel"
                   StyleClasses="LabelSubText"
                   HorizontalAlignment="Center"/>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
