<controls:FancyWindow xmlns="https://spacestation14.io"
        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
        xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
        Title="{Loc 'ui-achievements-title'}"
        SetSize="1200 800"
        MinSize="850 800">
    <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">
        <PanelContainer StyleClasses="BackgroundPanel" Margin="10 10 10 5">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="5">
                <Label Text="{Loc 'ui-achievements-progress'}" StyleClasses="LabelHeading" />
                <Control HorizontalExpand="True" />
                <Label Name="ProgressLabel" />
            </BoxContainer>
        </PanelContainer>

        <BoxContainer Orientation="Horizontal" VerticalExpand="True" HorizontalExpand="True" Margin="10 5 10 10">

            <ScrollContainer VerticalExpand="True" HorizontalExpand="True" MinWidth="500" HScrollEnabled="False">
                <BoxContainer Name="AchievementsList" Orientation="Vertical" SeparationOverride="10" HorizontalExpand="True" />
            </ScrollContainer>

            <PanelContainer StyleClasses="BackgroundPanel"
                          Margin="10 0 0 0"
                          Visible="False"
                          Name="SelectedAchievementPanel"
                          MinWidth="300"
                          VerticalExpand="True">
                <BoxContainer Orientation="Vertical" Margin="10" HorizontalExpand="True">
                    <BoxContainer HorizontalAlignment="Center" Margin="0 0 0 15">
                        <PanelContainer SetSize="152 152">
                            <PanelContainer.PanelOverride>
                                <graphics:StyleBoxFlat BackgroundColor="#1B1B1E" BorderColor="#2F6F3B" BorderThickness="4" />
                            </PanelContainer.PanelOverride>
                            <TextureRect Name="SelectedIcon"
                                       Stretch="KeepCentered"/>
                        </PanelContainer>
                    </BoxContainer>

                    <Label Name="SelectedName"
                          StyleClasses="LabelHeading"
                          HorizontalAlignment="Center"
                          Margin="0 0 0 5" />

                    <Label Name="SelectedStatus"
                          StyleClasses="LabelSubText"
                          HorizontalAlignment="Center"
                          Margin="0 0 0 10" />

                    <PanelContainer StyleClasses="BackgroundPanel" Margin="0 0 0 5" HorizontalExpand="True">
                        <BoxContainer Orientation="Vertical" Margin="5">
                            <Label Text="{Loc 'ui-achievements-description'}" StyleClasses="LabelSubText" Margin="0 0 0 2" />
                            <RichTextLabel Name="SelectedDescription"
                                         HorizontalExpand="True"
                                         VerticalExpand="True" />
                        </BoxContainer>
                    </PanelContainer>
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
